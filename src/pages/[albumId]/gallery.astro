---
const album = Astro.locals.album;
if (!album) {
  return Astro.redirect(`/${Astro.params.albumId}`);
}
const { albumId, albumName } = album;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{albumName} — Kort Amateur Photography</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div id="gallery-root" data-album-id={albumId} data-album-name={albumName}></div>
    <script>
      import { h, render } from "preact";
      import { Gallery } from "../../components/Gallery";

      const root = document.getElementById("gallery-root")!;
      const albumId = root.dataset.albumId!;
      const albumName = root.dataset.albumName!;

      render(h(Gallery, { albumId, albumName }), root);
    </script>
  </body>
</html>
