---
const { albumId } = Astro.params;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Enter Password</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main class="password-page">
      <div class="password-card">
        <div class="password-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1>View Album</h1>
        <p class="subtitle">Enter the password to access this gallery</p>
        <form id="pw-form">
          <input type="hidden" name="albumId" value={albumId} />
          <input
            type="password"
            name="password"
            placeholder="Album password"
            autocomplete="current-password"
            required
          />
          <button type="submit">
            <span class="btn-text">Continue</span>
            <span class="btn-loading" hidden>
              <svg class="spinner" width="20" height="20" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4" stroke-dashoffset="10" />
              </svg>
            </span>
          </button>
          <p class="error" id="pw-error" hidden></p>
        </form>
      </div>
    </main>
    <script>
      const form = document.getElementById("pw-form") as HTMLFormElement;
      const errorEl = document.getElementById("pw-error") as HTMLParagraphElement;
      const btn = form.querySelector("button") as HTMLButtonElement;
      const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
      const btnLoading = btn.querySelector(".btn-loading") as HTMLSpanElement;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.hidden = true;
        btn.disabled = true;
        btnText.hidden = true;
        btnLoading.hidden = false;

        const fd = new FormData(form);
        const albumId = fd.get("albumId") as string;
        const password = fd.get("password") as string;

        try {
          const res = await fetch("/api/auth", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ albumId, password }),
          });

          if (res.ok) {
            window.location.href = `/${albumId}/gallery`;
          } else {
            const data = await res.json();
            errorEl.textContent = data.error || "Invalid password";
            errorEl.hidden = false;
          }
        } catch {
          errorEl.textContent = "Something went wrong. Please try again.";
          errorEl.hidden = false;
        } finally {
          btn.disabled = false;
          btnText.hidden = false;
          btnLoading.hidden = true;
        }
      });
    </script>
  </body>
</html>
